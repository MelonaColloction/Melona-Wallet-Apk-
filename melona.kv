<AddTokenScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Add Token"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
        
        TextInput:
            id: contract_id
            hint_text: "Contract ID (e.g., DOGE-ABC123)"
            multiline: False
        
        Button:
            text: "Add Token"
            background_color: 0.1, 0.3, 0.5, 1
            on_release: root.add_token()
        
        Label:
            id: token_image
            text: "🪙"
            font_size: '60sp'
            color: 0.2, 0.8, 0.2, 1
            size_hint_y: 0.2
        
        Label:
            id: token_info
            text: ""
            color: 0.2, 0.8, 0.2, 1
        
        Label:
            id: result_label
            text: ""
            color: 0.2, 0.8, 0.2, 1
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main_menu'

<BalanceScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Balance"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
            size_hint_y: 0.08
        
        ScrollView:
            Label:
                id: balance_text
                text: ""
                size_hint_y: None
                text_size: self.width, None
                height: self.texture_size[1]
                color: 0.9, 0.9, 0.9, 1
                markup: True
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main_menu'

<StatsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Statistics"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
            size_hint_y: 0.08
        
        ScrollView:
            Label:
                id: stats_text
                text: ""
                size_hint_y: None
                text_size: self.width, None
                height: self.texture_size[1]
                color: 0.9, 0.9, 0.9, 1
                markup: True
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main_menu'