<TransferMLEScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Transfer MLE"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
        
        TextInput:
            id: to_address
            hint_text: "Recipient Address"
            multiline: False
        
        TextInput:
            id: amount
            hint_text: "Amount"
            multiline: False
        
        Button:
            text: "Transfer"
            background_color: 0.1, 0.2, 0.6, 1
            on_release: root.transfer_mle()
        
        Label:
            id: result_label
            text: ""
            color: 0.2, 0.8, 0.2, 1
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main_menu'

<CreateMemeCoinScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 5
        
        Label:
            text: "Create Meme Coin"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
        
        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
                padding: 5
                
                TextInput:
                    id: coin_name
                    hint_text: "Coin Name"
                    multiline: False
                    size_hint_y: None
                    height: 40
                
                TextInput:
                    id: coin_symbol
                    hint_text: "Symbol (e.g., DOGE)"
                    multiline: False
                    size_hint_y: None
                    height: 40
                
                TextInput:
                    id: coin_decimals
                    hint_text: "Decimals (0-18, Enter for 0)"
                    multiline: False
                    size_hint_y: None
                    height: 40
                
                TextInput:
                    id: coin_supply
                    hint_text: "Total Supply (Enter for 1,000,000)"
                    multiline: False
                    size_hint_y: None
                    height: 40
                
                TextInput:
                    id: coin_logo
                    hint_text: "Logo Emoji (Enter for 🪙)"
                    multiline: False
                    size_hint_y: None
                    height: 40
                
                Button:
                    text: "Select Logo Image"
                    size_hint_y: None
                    height: 50
                    background_color: 0.2, 0.4, 0.8, 1
                    on_release: root.select_image()
                
                Label:
                    id: image_preview
                    text: "No image selected"
                    color: 0.5, 0.5, 0.5, 1
                    size_hint_y: None
                    height: 30
        
        Button:
            text: "Create Meme Coin"
            size_hint_y: 0.08
            background_color: 0.1, 0.6, 0.1, 1
            on_release: root.create_meme()
        
        Label:
            id: result_label
            text: ""
            color: 0.2, 0.8, 0.2, 1
            size_hint_y: 0.15
        
        Label:
            id: contract_id_label
            text: ""
            color: 0.2, 0.8, 0.2, 1
            size_hint_y: 0.08
        
        Button:
            text: "Back"
            size_hint_y: 0.07
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main_menu'

<ListMemeCoinsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Meme Coins"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
            size_hint_y: 0.08
        
        ScrollView:
            GridLayout:
                id: coins_grid
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
                padding: 5
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main_menu'

<BuyMemeCoinScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Buy Meme Coin"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
        
        Spinner:
            id: coins_spinner
            text: "Select coin"
            values: []
            size_hint_y: 0.1
        
        TextInput:
            id: amount
            hint_text: "Amount (Enter for 1)"
            multiline: False
        
        Button:
            text: "Buy"
            background_color: 0.1, 0.6, 0.1, 1
            on_release: root.buy_meme()
        
        Label:
            id: result_label
            text: ""
            color: 0.2, 0.8, 0.2, 1
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main_menu'

