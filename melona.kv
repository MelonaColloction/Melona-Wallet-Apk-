<MainScreen>:
    canvas.before:
        Color:
            rgba: 0.05, 0.1, 0.05, 1
        Rectangle:
            pos: self.pos
            size: self.size
    
    BoxLayout:
        orientation: 'vertical'
        padding: 30
        spacing: 15
        
        Image:
            source: 'melona_logo.png' if os.path.exists('melona_logo.png') else ''
            size_hint_y: 0.35
            allow_stretch: True
            keep_ratio: True
        
        Label:
            text: "🍉 Melona Wallet"
            font_size: '45sp'
            color: 0.2, 0.9, 0.2, 1
            bold: True
            size_hint_y: 0.1
        
        Label:
            text: "Multi-Token Blockchain Wallet"
            font_size: '16sp'
            color: 0.7, 0.7, 0.7, 1
            size_hint_y: 0.05
        
        Button:
            text: "Create Wallet"
            size_hint_y: 0.12
            background_normal: ''
            background_color: 0.1, 0.6, 0.1, 1
            font_size: '18sp'
            bold: True
            on_release: root.manager.current = 'create_wallet'
        
        Button:
            text: "Recover Wallet"
            size_hint_y: 0.12
            background_normal: ''
            background_color: 0.15, 0.4, 0.15, 1
            font_size: '18sp'
            bold: True
            on_release: root.manager.current = 'recover_wallet'
        
        Button:
            text: "Main Menu"
            size_hint_y: 0.12
            background_normal: ''
            background_color: 0.2, 0.5, 0.2, 1
            font_size: '18sp'
            bold: True
            on_release: root.manager.current = 'main_menu'
        
        Label:
            text: "v1.0"
            font_size: '12sp'
            color: 0.4, 0.4, 0.4, 1
            size_hint_y: 0.05

<CreateWalletScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Create Wallet"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
        
        TextInput:
            id: wallet_name
            hint_text: "Wallet Name (optional)"
            multiline: False
        
        Button:
            text: "Create"
            background_color: 0.1, 0.6, 0.1, 1
            on_release: root.create_wallet()
        
        Label:
            id: result_label
            text: ""
            color: 0.2, 0.8, 0.2, 1
        
        Label:
            id: full_address
            text: ""
            font_size: '12sp'
            color: 0.7, 0.7, 0.7, 1
        
        Label:
            id: full_private
            text: ""
            font_size: '12sp'
            color: 0.8, 0.3, 0.3, 1
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main'

<RecoverWalletScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Recover Wallet"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
        
        TextInput:
            id: private_key
            hint_text: "Enter Private Key"
            multiline: False
        
        Button:
            text: "Recover"
            background_color: 0.1, 0.6, 0.1, 1
            on_release: root.recover_wallet()
        
        Label:
            id: result_label
            text: ""
            color: 0.2, 0.8, 0.2, 1
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main'

<MainMenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 5
        
        Label:
            id: wallet_info
            text: "🔑 No wallet loaded"
            font_size: '16sp'
            color: 0.2, 0.8, 0.2, 1
            size_hint_y: 0.05
        
        GridLayout:
            cols: 2
            spacing: 5
            size_hint_y: 0.85
            
            Button:
                text: "Buy MLE"
                background_color: 0.1, 0.5, 0.1, 1
                on_release: root.manager.current = 'buy_mle'
            Button:
                text: "Sell MLE"
                background_color: 0.4, 0.1, 0.1, 1
                on_release: root.manager.current = 'sell_mle'
            Button:
                text: "Transfer MLE"
                background_color: 0.1, 0.2, 0.6, 1
                on_release: root.manager.current = 'transfer_mle'
            Button:
                text: "Create Meme"
                background_color: 0.6, 0.4, 0.1, 1
                on_release: root.manager.current = 'create_meme'
            Button:
                text: "List Memes"
                background_color: 0.1, 0.4, 0.4, 1
                on_release: root.manager.current = 'list_meme'
            Button:
                text: "Buy Meme"
                background_color: 0.1, 0.5, 0.1, 1
                on_release: root.manager.current = 'buy_meme'
            Button:
                text: "Sell Meme"
                background_color: 0.4, 0.1, 0.1, 1
                on_release: root.manager.current = 'sell_meme'
            Button:
                text: "Add Token"
                background_color: 0.1, 0.3, 0.5, 1
                on_release: root.manager.current = 'add_token'
            Button:
                text: "Balance"
                background_color: 0.2, 0.4, 0.2, 1
                on_release: root.manager.current = 'balance'
            Button:
                text: "Stats"
                background_color: 0.3, 0.2, 0.5, 1
                on_release: root.manager.current = 'stats'
        
        Button:
            text: "Back"
            size_hint_y: 0.07
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main'

<BuyMLEScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        
        Label:
            text: "Buy MLE"
            font_size: '30sp'
            color: 0.2, 0.8, 0.2, 1
        
        TextInput:
            id: amount
            hint_text: "Amount (Enter for 0.01)"
            multiline: False
        
        Button:
            text: "Buy"
            background_color: 0.1, 0.6, 0.1, 1
            on_release: root.buy_mle()
        
        Label:
            id: result_label
            text: ""
            color: 0.2, 0.8, 0.2, 1
        
        Button:
            text: "Back"
            size_hint_y: 0.08
            background_color: 0.5, 0.2, 0.2, 1
            on_release: root.manager.current = 'main_menu'

